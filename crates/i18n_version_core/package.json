{
  "name": "i18n-version-core",
  "version": "0.1.0",
  "private": true,
  "description": "Native module for vite-plugin-i18n-version",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "napi": {
    "binaryName": "i18n-version-core",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release --strip --no-js --output-dir ../../packages/vite-plugin-i18n-version/dist",
    "build:debug": "napi build --platform --no-js --output-dir ../../packages/vite-plugin-i18n-version/dist"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  }
}